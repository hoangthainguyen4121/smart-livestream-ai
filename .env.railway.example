# Railway deployment — copy values after creating services in Railway dashboard.
# Do NOT commit real production secrets.

# ========== BACKEND SERVICE ==========
# Railway auto-injects PORT — do not set manually.

# Required after frontend is deployed (exact public HTTPS origin):
CORS_ORIGINS=https://YOUR-FRONTEND.up.railway.app

# Optional — leave unset for rules fallback (recommended on free tier):
# ML_INTENT_API_URL=https://your-ml-service.up.railway.app
ML_INTENT_TIMEOUT_SECONDS=2

# Camera product recognition (frontend-only, flag-gated). Keep false on Railway free tier.
VITE_ENABLE_CAMERA_PRODUCT_RECOGNITION=false
CAMERA_PRODUCT_RECOGNITION_ENABLED=false

# ========== FRONTEND SERVICE (build-time variables) ==========
# In Railway: Variables → enable "Available at Build" for both.

# Backend public HTTPS URL (no trailing slash):
VITE_API_BASE_URL=https://YOUR-BACKEND.up.railway.app

# WebSocket base (wss). Usually same host as API:
VITE_WS_BASE_URL=wss://YOUR-BACKEND.up.railway.app

# If VITE_WS_BASE_URL is omitted, frontend derives wss:// from VITE_API_BASE_URL automatically.
