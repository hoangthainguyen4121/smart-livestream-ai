# Browser-facing API URL (must be reachable from your host browser, not the Docker service name).
VITE_API_BASE_URL=http://127.0.0.1:8000

# Comma-separated frontend origins allowed by backend CORS.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080

# Camera product recognition (catalog-scoped, lightweight, frontend-only). Default false on cloud.
VITE_ENABLE_CAMERA_PRODUCT_RECOGNITION=false
CAMERA_PRODUCT_RECOGNITION_ENABLED=false

# --- Optional: PhoBERT intent ML service (smart-livestream-ml repo, NOT in this compose) ---
# Start separately: python scripts/serve_intent_api.py --model-dir ../smart-livestream-ml/artifacts/phobert_base_combined_hardcases_v3 --port 8010
# Fallback: ../smart-livestream-ml/artifacts/phobert_base_combined_hardcases_v2
# Docker backend defaults to host.docker.internal so a host-run ML API is reachable.
ML_INTENT_API_URL=http://127.0.0.1:8010
ML_INTENT_TIMEOUT_SECONDS=2
