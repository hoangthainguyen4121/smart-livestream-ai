# Browser-facing API URL (must be reachable from your host browser, not the Docker service name).
VITE_API_BASE_URL=http://127.0.0.1:8000

# Comma-separated frontend origins allowed by backend CORS.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Temporarily disabled by default. Set true to re-enable Wave gesture detection.
ENABLE_WAVE_GESTURE=false
