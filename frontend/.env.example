# Copy to `.env.local` for local dev (see frontend/.env.local).
# Railway/cloud: keep vision recognition disabled unless backend has optional CLIP deps.

VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_ENABLE_CAMERA_PRODUCT_RECOGNITION=false

# Hand-held product vision (MediaPipe Hands + backend visual embeddings).
# Requires backend HAND_HELD_VISION_ENABLED=true and optional pip install -r requirements-vision.txt
VITE_ENABLE_HAND_HELD_VISION=false

# Optional login with Supabase Auth + Google OAuth.
# Google Client ID/Secret: configure in Supabase Dashboard → Authentication → Providers → Google.
# Leave these empty to keep guest-only chat.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-public-key
